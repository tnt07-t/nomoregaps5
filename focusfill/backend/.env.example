USE_MOCK_DATA=true
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
ANTHROPIC_API_KEY=your_anthropic_api_key

# Frontend origins allowed by CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for preview domains (example for Vercel previews)
# FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app

# DB (for production use Postgres; local defaults to sqlite if omitted)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

SECRET_KEY=your_secret_key_here
